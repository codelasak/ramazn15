# Pano15 mobile build icin gerekli ortam degiskenleri.
# Kullanim: cp .env.mobile.example .env.mobile.local
# Sonra `set -a && source .env.mobile.local && set +a && npm run mobile:build`

# Mobil app'in cagiracagi REST API kok URL'i (slash ile bitmemeli).
NEXT_PUBLIC_API_URL=https://15temmuz.fennaver.tech

# JWT token icin custom auth endpoint'lerinin alt yolu.
NEXT_PUBLIC_AUTH_BASE=/api/auth

# Mobile build icin Sentry / analytics (opsiyonel).
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_ANALYTICS_KEY=
